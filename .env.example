# MiniMax (NOT api.minimax.chat — that's the Chinese MiniMax, different service)
# Get a key at https://platform.MiniMax.io — same provider as Mavis LLM
MINIMAX_API_KEY=sk-MiniMax-...

# Optional overrides (defaults shown)
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_EMBEDDING_MODEL=MiniMax-Text-01
MINIMAX_LLM_MODEL=MiniMax-Text-01
EMBEDDING_DIM=1536

# Where to store the SQLite DB
DB_PATH=./data/code-doc.db